<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Block all cleartext traffic except loopback (OAuth callback server) -->
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
    </domain-config>

    <!-- Pin certs for Anthropic API -->
    <domain-config>
        <domain includeSubdomains="true">api.anthropic.com</domain>
        <domain includeSubdomains="true">claude.ai</domain>
        <domain includeSubdomains="true">platform.claude.com</domain>
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </domain-config>
</network-security-config>
