<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="@color/colorSurface">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Claude Widget"
        android:textColor="@color/text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingBottom="24dp" />

    <Button
        android:id="@+id/btn_sign_in"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/auth_button"
        android:backgroundTint="@color/colorButton"
        android:textColor="@color/text_primary"
        android:paddingStart="32dp"
        android:paddingEnd="32dp" />

    <!-- Code paste area — shown after user returns from Chrome -->
    <LinearLayout
        android:id="@+id/layout_code_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Paste the authorization code here:"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:paddingBottom="8dp" />

        <EditText
            android:id="@+id/et_auth_code"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Authorization code"
            android:textColor="@color/text_primary"
            android:textColorHint="#80FFFFFF"
            android:backgroundTint="@color/text_secondary"
            android:inputType="text"
            android:singleLine="true"
            android:paddingBottom="12dp" />

        <Button
            android:id="@+id/btn_submit_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Submit Code"
            android:backgroundTint="@color/colorButton"
            android:textColor="@color/text_primary"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btn_test_fetch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Test Fetch"
        android:backgroundTint="#335577"
        android:textColor="@color/text_primary"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/tv_debug"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#AAAAAA"
        android:textSize="11sp"
        android:fontFamily="monospace"
        android:paddingTop="12dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btn_sign_out"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sign_out"
        android:visibility="gone" />

</LinearLayout>
